@model Lab4_Productos_JuanMurillo.Models.Producto

<h2>Crear Producto</h2>

<form asp-controller="Productos" asp-action="Crear" method="post">

    <div>
        <label>Nombre</label>
        <input asp-for="Nombre" />
        <span asp-validation-for="Nombre"></span>
    </div>

    <div>
        <label>Precio</label>
        <input asp-for="Precio" type ="number" step="0.01" />
        <span asp-validation-for="Precio"></span>
    </div>

    <div>
        <label>Categoría</label>
        <select asp-for="Categoria">
            <option value="">--Seleccione--</option>
            <option>Electrónica</option>
            <option>Ropa</option>
            <option>Hogar</option>
            <option>Alimentos</option>
        </select>
        <span asp-validation-for="Categoria"></span>
    </div>

    <button type="submit">Guardar</button>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}